# Proton credentials stay on the local computer.
PROTON_USERNAME=
PROTON_PASSWORD=
PROTON_TOTP_SECRET=
PROTON_LOGIN_TYPE=web

# Securely copy runtime/mail_relay_secret from the server to this directory.
MAIL_RELAY_URL=https://your-server.example.com/api/internal/mail-relay
MAIL_RELAY_SECRET_FILE=mail_relay_secret
MAIL_RELAY_ACCOUNT=account-4
MAIL_RELAY_TIMEOUT_SECONDS=15

PROTON_RELAY_SESSION_FILE=runtime/proton_sessions/account-4.pickle
PROTON_POLL_INTERVAL_SECONDS=3
PROTON_KEEPALIVE_SECONDS=300
PROTON_CATCHUP_LIMIT=30
OPENAI_CODE_SENDERS=noreply@tm.openai.com,noreply@tm1.openai.com
